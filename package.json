{
  "name": "peace-mind-meet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "nuxi dev client --host 127.0.0.1 --port 3000",
    "server:dev": "tsx watch server/src/index.ts",
    "build": "npm run client:build && npm run server:build",
    "client:build": "nuxi build client",
    "client:generate": "nuxi generate client",
    "server:build": "tsc -p server/tsconfig.json",
    "typecheck": "vue-tsc --noEmit -p client/tsconfig.json && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@vueuse/core": "^13.5.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-vue-next": "^0.468.0",
    "nuxt": "^3.17.6",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^20.19.1",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10"
  }
}
